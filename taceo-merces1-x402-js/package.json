{
  "name": "@taceo/confidential-x402",
  "version": "1.0.1",
  "description": "Confidential x402 scheme by TACEO",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/esm/server/index.d.mts",
        "default": "./dist/esm/server/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/server/index.d.ts",
        "default": "./dist/cjs/server/index.js"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/esm/client/index.d.mts",
        "default": "./dist/esm/client/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/client/index.d.ts",
        "default": "./dist/cjs/client/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "example:client": "tsx examples/client.ts",
    "example:server": "tsx examples/server.ts"
  },
  "files": [
    "dist/**"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.12.0",
    "@x402/express": "^2.10.0",
    "@x402/fetch": "^2.10.0",
    "express": "^4.18.2",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@taceo/merces1-client": "^1.0.0",
    "@types/snarkjs": "^0.7.9",
    "@x402/core": "^2.10.0",
    "@x402/evm": "^2.10.0",
    "snarkjs": "^0.7.6",
    "viem": "^2.46.3",
    "x402": "^1.2.0"
  }
}
